# ========================================
# CalorieSight 環境変数設定
# ========================================
# このファイルを .env にコピーして、APIキーを設定してください。
#   cp .env.example .env
#
# APIキーが未設定でもデモモードで動作します。

# Gemini API Key（メインの食事写真認識用）
# 取得先: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Claude API Key（フォールバック認識 + 週次AIコーチング用）
# 取得先: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=
